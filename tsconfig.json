{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "server.cjs",
    "server/**/*.cjs",
    "scripts/start-production.cjs",
    "scripts/production-startup-check.cjs",
    "types/**/*.d.ts"
  ]
}
