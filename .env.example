# Runtime. npm start always forces NODE_ENV=production; npm run start:development honors this value.
NODE_ENV=development
HOST=127.0.0.1
PORT=4173
PUBLIC_URL=http://127.0.0.1:4173
LOG_LEVEL=info

# Set TRUST_PROXY=true only behind a trusted reverse proxy that replaces X-Forwarded-For.
TRUST_PROXY=false
SIGNATURE_ONLY=false
SIGNATURE_SESSION_HOURS=12
SIGNATURE_ALLOW_DEFAULT_ADMIN=false

# Data. Production requires explicit absolute DATABASE_PATH and BACKUP_DIRECTORY values.
# Windows examples: C:\ProgramData\Northstar\data\northstar.db and C:\ProgramData\Northstar\backups
DATABASE_PATH=./data/northstar.db
BACKUP_DIRECTORY=./backups
BACKUP_RETENTION_DAYS=35

# Local demo data is opt-in and is rejected by production startup.
SEED_DEMO_DATA=false
DEMO_MODE=false

# Generate with: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
# Store in the production secret manager, never in source control or the backup directory.
NORTHSTAR_BACKUP_KEY=

# Retention periods. Production audit retention cannot be shorter than 365 days.
RETENTION_AUDIT_DAYS=2555
RETENTION_SYNC_DAYS=365
RETENTION_SECURITY_DAYS=90

# Microsoft Entra application registration. Required unless SIGNATURE_ONLY=true.
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_API_AUDIENCE=api://00000000-0000-0000-0000-000000000000
ENTRA_API_SCOPE=api://00000000-0000-0000-0000-000000000000/Portal.Access
ENTRA_ALLOWED_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_REDIRECT_URI=http://127.0.0.1:4173

# ConnectWise Platform OAuth 2.0 client credentials. Leave both blank to disable synchronization.
CONNECTWISE_BASE_URL=https://openapi.service.itsupport247.net
CONNECTWISE_CLIENT_ID=
CONNECTWISE_CLIENT_SECRET=
CONNECTWISE_SCOPE=platform.companies.read platform.tickets.read
CONNECTWISE_COMPANIES_PATH=/v1/companies
CONNECTWISE_TICKETS_PATH=/v1/tickets
